<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="WarpButtonCompat">
        <attr name="warpButtonStyle" format="enum">
            <enum name="primary" value="0" />
            <enum name="secondary" value="1" />
            <enum name="tertiary" value="2" />
            <enum name="critical" value="3" />
            <enum name="criticalQuiet" value="4" />
            <enum name="utility" value="5" />
            <enum name="utilityQuiet" value="6" />
            <enum name="utilityOverlay" value="7" />
        </attr>
        <attr name="warpButtonText" format="string"/>
        <attr name="warpButtonEnabled" format="boolean"/>
        <attr name="warpButtonLoading" format="boolean"/>
    </declare-styleable>
</resources>