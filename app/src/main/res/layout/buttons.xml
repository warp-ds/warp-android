<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.schibsted.nmp.warp.components.WarpButtonCompat
        android:id="@+id/compose_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:layout_constraintBottom_toTopOf="@id/compose_view2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:warpButtonLoading="false"
        app:warpButtonStyle="primary"
        app:warpButtonText="Buy some ducks" />

    <com.schibsted.nmp.warp.components.WarpButtonCompat
        android:id="@+id/compose_view2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:layout_constraintBottom_toTopOf="@id/compose_view3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/compose_view"
        app:warpButtonStyle="secondary"
        app:warpButtonText="Buy some ducks" />

    <com.schibsted.nmp.warp.components.WarpButtonCompat
        android:id="@+id/compose_view3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/compose_view2"
        app:warpButtonStyle="critical"
        app:warpButtonText="Buy some ducks" />

</androidx.constraintlayout.widget.ConstraintLayout>